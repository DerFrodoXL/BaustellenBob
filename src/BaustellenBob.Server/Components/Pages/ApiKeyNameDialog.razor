<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Name" Label="Name des API-Schlüssels" Required="true"
                      Placeholder="z. B. ERP-Integration" AutoFocus="true" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="string.IsNullOrWhiteSpace(Name)">Erstellen</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;

    public string Name { get; set; } = string.Empty;

    private void Cancel() => MudDialog.Cancel();
    private void Submit() => MudDialog.Close(DialogResult.Ok(Name.Trim()));
}
