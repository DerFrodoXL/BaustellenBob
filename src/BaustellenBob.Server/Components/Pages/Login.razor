@page "/login"
@attribute [AllowAnonymous]
@layout BaustellenBob.Server.Components.Layout.EmptyLayout

<PageTitle>BaustellenBob - Login</PageTitle>

<div style="display:flex; justify-content:center; align-items:center; min-height:100vh;">
    <MudCard Style="width:400px; max-width:95vw;">
        <MudCardHeader>
            <div style="width:100%; text-align:center;">
                <MudImage Src="/structra-logo.png" Alt="Structra Logo" Style="max-width:220px; width:100%; height:auto; margin:0 auto 8px auto;" />
                <MudText Typo="Typo.h6" Align="Align.Center" Style="width:100%">
                    Structra Login
                </MudText>
            </div>
        </MudCardHeader>
        <MudCardContent>
            @if (_error)
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">E-Mail oder Passwort falsch.</MudAlert>
            }
            <form method="post"
                action="/api/auth/login"
                onsubmit="const email=document.getElementById('email'); const password=document.getElementById('password'); const hiddenEmail=document.getElementById('email_hidden'); const hiddenPassword=document.getElementById('password_hidden'); if(hiddenEmail&&email){hiddenEmail.value=email.value;} if(hiddenPassword&&password){hiddenPassword.value=password.value;} const btn=this.querySelector('button[type=submit]'); if(btn){btn.disabled=true; const idle=btn.querySelector('[data-idle]'); const loading=btn.querySelector('[data-loading]'); if(idle){idle.style.display='none';} if(loading){loading.style.display='inline-flex';}}">
                <AntiforgeryToken />
                <input type="hidden" id="email_hidden" name="email" />
                <input type="hidden" id="password_hidden" name="password" />
                <MudTextField T="string"
                              Label="E-Mail"
                              InputId="email"
                              InputType="InputType.Email"
                              Required="true"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Class="mb-3" />
                <MudTextField T="string"
                              Label="Passwort"
                              InputId="password"
                              InputType="InputType.Password"
                              Required="true"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Class="mb-3" />
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                           Color="Color.Primary" FullWidth="true" Class="mt-2">
                    <span data-idle>Anmelden</span>
                    <span data-loading style="display:none; align-items:center; gap:8px;">
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" />
                        Anmeldung laeuft...
                    </span>
                </MudButton>
            </form>
        </MudCardContent>
        <MudCardActions Style="flex-direction:column; align-items:center; gap:8px;">
            <MudLink Href="/register" Typo="Typo.body2">Noch kein Konto? Jetzt registrieren</MudLink>
            <div style="display:flex; gap:12px; flex-wrap:wrap; justify-content:center;">
                <MudLink Href="/impressum" Typo="Typo.caption">Impressum</MudLink>
                <MudLink Href="/agb" Typo="Typo.caption">AGB</MudLink>
                <MudLink Href="/tos" Typo="Typo.caption">ToS</MudLink>
            </div>
            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                Demo: demo@baustellenbob.de / demo1234
            </MudText>
        </MudCardActions>
    </MudCard>
</div>

@code {
    private bool _error;

    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorParam { get; set; }

    protected override void OnInitialized()
    {
        _error = ErrorParam == "1";
    }
}
