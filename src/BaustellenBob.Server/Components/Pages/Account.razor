@page "/account"
@attribute [Authorize(Roles = "Admin")]
@using Microsoft.AspNetCore.Components.Forms

<PageTitle>Konto & Abo</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Konto & Abo</MudText>

@if (_successMessage is not null)
{
    <MudAlert Severity="Severity.Success" Class="mb-3">@_successMessage</MudAlert>
}
@if (_canceledMessage is not null)
{
    <MudAlert Severity="Severity.Warning" Class="mb-3">@_canceledMessage</MudAlert>
}

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true">
    @* ──── Tab 1: Konto ──── *@
    <MudTabPanel Text="Konto" Icon="@Icons.Material.Filled.Business">
        @if (_limits is null || _usage is null)
        {
            <MudProgressCircular Indeterminate="true" />
        }
        else
        {
            <MudGrid>
                @* Company Logo *@
                <MudItem xs="12" md="6">
                    <MudCard>
                        <MudCardHeader>
                            <MudText Typo="Typo.h6">Firmenlogo</MudText>
                        </MudCardHeader>
                        <MudCardContent>
                            <div class="d-flex align-center gap-4 mb-3">
                                @if (!string.IsNullOrEmpty(_previewUrl))
                                {
                                    <MudImage Src="@_previewUrl" Alt="Firmenlogo" Style="max-height:80px;max-width:200px;object-fit:contain;" />
                                }
                                else if (!string.IsNullOrEmpty(_logoPath))
                                {
                                    <MudImage Src="@($"/uploads/{_logoPath}")" Alt="Firmenlogo" Style="max-height:80px;max-width:200px;object-fit:contain;" />
                                }
                                else
                                {
                                    <MudIcon Icon="@Icons.Material.Filled.Business" Style="font-size:64px;" Class="mud-text-secondary" />
                                }
                            </div>
                            @if (_logoError is not null)
                            {
                                <MudAlert Severity="Severity.Error" Class="mb-2">@_logoError</MudAlert>
                            }
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">PNG, JPG oder WebP — max. 2 MB. Wird in der App-Leiste angezeigt.</MudText>
                            <InputFile id="logoInput" OnChange="OnLogoSelected" accept="image/*" style="display:none;" />
                            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                       OnClick="@(() => _jsRuntime.InvokeVoidAsync("eval", "document.getElementById('logoInput').click()"))">
                                Logo auswählen
                            </MudButton>
                            @if (_pendingLogo is not null)
                            {
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                           Class="ml-2" OnClick="SaveLogo" Disabled="_savingLogo">
                                    @(_savingLogo ? "Speichern..." : "Speichern")
                                </MudButton>
                            }
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Feature table *@
                <MudItem xs="12" md="6">
                    <MudCard>
                        <MudCardHeader>
                            <MudText Typo="Typo.h6">Features</MudText>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudSimpleTable Dense="true" Hover="true">
                                <tbody>
                                    <tr>
                                        <td>PDF Export</td>
                                        <td>
                                            @if (_limits.PdfExport)
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Small" />
                                            }
                                            else
                                            {
                                                <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" Size="Size.Small" />
                                            }
                                        </td>
                                    </tr>
                                </tbody>
                            </MudSimpleTable>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudCard>
                        <MudCardHeader>
                            <MudText Typo="Typo.h6">Währung</MudText>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">
                                Standard ist EUR. Diese Währung wird bei Preisangaben in der App verwendet.
                            </MudText>
                            <div class="d-flex align-center gap-2 flex-wrap">
                                <MudSelect T="string" Value="_currencyCode" ValueChanged="OnCurrencyChanged" Label="Währung" Dense="true" Style="min-width:180px;">
                                    @foreach (var currency in _currencies)
                                    {
                                        <MudSelectItem T="string" Value="@currency">@currency</MudSelectItem>
                                    }
                                </MudSelect>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveCurrency" Disabled="_savingCurrency || !_currencyDirty">
                                    @(_savingCurrency ? "Speichern..." : "Speichern")
                                </MudButton>
                            </div>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                <MudItem xs="12" md="6">
                    <MudCard>
                        <MudCardHeader>
                            <MudText Typo="Typo.h6">Arbeitstage</MudText>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary mb-2">
                                Diese Tage werden in der Einsatzplanung berücksichtigt. Standard ist Montag bis Freitag.
                            </MudText>
                            <MudGrid>
                                @foreach (var option in _workingDayOptions)
                                {
                                    <MudItem xs="6" sm="4">
                                        <MudCheckBox T="bool"
                                                     Label="@option.Label"
                                                     Value="@_workingDays.Contains(option.Day)"
                                                     ValueChanged="@(value => OnWorkingDayToggled(option.Day, value))" />
                                    </MudItem>
                                }
                            </MudGrid>
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-2"
                                       OnClick="SaveWorkingDays" Disabled="_savingWorkingDays || !_workingDaysDirty">
                                @(_savingWorkingDays ? "Speichern..." : "Speichern")
                            </MudButton>
                        </MudCardContent>
                    </MudCard>
                </MudItem>

                @* Usage *@
                <MudItem xs="12">
                    <MudCard>
                        <MudCardHeader>
                            <MudText Typo="Typo.h6">Verbrauch</MudText>
                        </MudCardHeader>
                        <MudCardContent>
                            <MudGrid>
                                <MudItem xs="12" sm="6" md="3">
                                    <UsageBar Label="Aktive Baustellen" Current="_usage.Projects" Max="_limits.MaxActiveProjects" />
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <UsageBar Label="Mitarbeiter" Current="_usage.Employees" Max="_limits.MaxEmployees" />
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <UsageBar Label="Fotos" Current="_usage.Photos" Max="_limits.MaxPhotos" />
                                </MudItem>
                                <MudItem xs="12" sm="6" md="3">
                                    <UsageBar Label="Rapporte" Current="_usage.Reports" Max="_limits.MaxReports" />
                                </MudItem>
                            </MudGrid>
                        </MudCardContent>
                    </MudCard>
                </MudItem>
            </MudGrid>
        }
    </MudTabPanel>

    @* ──── Tab 2: Abo & Tarife ──── *@
    <MudTabPanel Text="Abo & Tarife" Icon="@Icons.Material.Filled.CreditCard">
        @if (_stripeLoading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
        }
        else if (_stripeInfo is not null)
        {
            <MudCard Class="mb-4">
                <MudCardContent>
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Aktueller Tarif</MudText>
                            <MudText Typo="Typo.h6">
                                <MudChip T="string" Color="@TierColor(_stripeInfo.CurrentTier)" Size="Size.Small">@_stripeInfo.CurrentTier</MudChip>
                            </MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            @if (_stripeInfo.Status is not null)
                            {
                                <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Abo-Status</MudText>
                                <MudText Typo="Typo.body1">@TranslateStatus(_stripeInfo.Status)</MudText>
                            }
                        </MudItem>
                        @if (_stripeInfo.CurrentPeriodEnd.HasValue)
                        {
                            <MudItem xs="12">
                                <MudText Typo="Typo.subtitle2" Class="mud-text-secondary">Nächste Abrechnung</MudText>
                                <MudText Typo="Typo.body1">@_stripeInfo.CurrentPeriodEnd.Value.ToLocalTime().ToString("dd.MM.yyyy")</MudText>
                            </MudItem>
                        }
                    </MudGrid>
                </MudCardContent>
                @if (_stripeInfo.CanManage)
                {
                    <MudCardActions>
                        <form method="post" action="/api/stripe/portal">
                            <AntiforgeryToken />
                            <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Outlined" Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Settings">
                                Abo im Stripe Portal verwalten
                            </MudButton>
                        </form>
                    </MudCardActions>
                }
            </MudCard>

            <MudText Typo="Typo.h6" Class="mb-3">Verfügbare Tarife</MudText>

            <MudGrid>
                @foreach (var plan in _plans)
                {
                    var isCurrent = plan.Tier == _stripeInfo.CurrentTier;
                    <MudItem xs="12" sm="6" md="3">
                        <MudCard Outlined="true" Style="@(isCurrent ? "border:2px solid var(--mud-palette-primary);" : "")">
                            <MudCardHeader>
                                <MudText Typo="Typo.h6" Align="Align.Center" Style="width:100%">@plan.Name</MudText>
                            </MudCardHeader>
                            <MudCardContent Style="text-align:center;">
                                <MudText Typo="Typo.h4" Color="Color.Primary">@plan.Price</MudText>
                                <MudText Typo="Typo.caption" Class="mud-text-secondary">pro Monat</MudText>
                                <MudDivider Class="my-2" />
                                <MudText Typo="Typo.body2">@plan.Baustellen aktive Baustellen</MudText>
                                <MudText Typo="Typo.body2">@plan.Mitarbeiter Mitarbeiter</MudText>
                                <MudText Typo="Typo.body2">@plan.Fotos Fotos</MudText>
                                <MudText Typo="Typo.body2">PDF Export: @(plan.PdfExport ? "Ja" : "Nein")</MudText>
                            </MudCardContent>
                            <MudCardActions Style="justify-content:center;">
                                @if (isCurrent)
                                {
                                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="true">
                                        Aktueller Tarif
                                    </MudButton>
                                }
                                else if (plan.Tier == BaustellenBob.Domain.Enums.Tier.Free)
                                {
                                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Kostenlos</MudText>
                                }
                                else
                                {
                                    <form method="post" action="/api/stripe/checkout">
                                        <AntiforgeryToken />
                                        <input type="hidden" name="tier" value="@plan.Tier" />
                                        <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary">
                                            Auswählen
                                        </MudButton>
                                    </form>
                                }
                            </MudCardActions>
                        </MudCard>
                    </MudItem>
                }
            </MudGrid>
        }
    </MudTabPanel>
</MudTabs>

@code {
    [Inject] private ITierLimitService TierLimitService { get; set; } = null!;
    [Inject] private ITenantService TenantService { get; set; } = null!;
    [Inject] private IStripeService StripeService { get; set; } = null!;
    [Inject] private IJSRuntime _jsRuntime { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    // Konto state
    private TierLimit? _limits;
    private TierUsage? _usage;
    private string? _logoPath;
    private string? _previewUrl;
    private IBrowserFile? _pendingLogo;
    private bool _savingLogo;
    private string? _logoError;
    private string _currencyCode = "EUR";
    private bool _currencyDirty;
    private bool _savingCurrency;
    private HashSet<DayOfWeek> _workingDays = new();
    private bool _workingDaysDirty;
    private bool _savingWorkingDays;
    private static readonly string[] _currencies = ["EUR", "CHF", "USD", "GBP"];
    private static readonly WorkingDayOption[] _workingDayOptions =
    [
        new(DayOfWeek.Monday, "Montag"),
        new(DayOfWeek.Tuesday, "Dienstag"),
        new(DayOfWeek.Wednesday, "Mittwoch"),
        new(DayOfWeek.Thursday, "Donnerstag"),
        new(DayOfWeek.Friday, "Freitag"),
        new(DayOfWeek.Saturday, "Samstag"),
        new(DayOfWeek.Sunday, "Sonntag")
    ];

    // Stripe state
    private SubscriptionInfo? _stripeInfo;
    private bool _stripeLoading = true;
    private string? _successMessage;
    private string? _canceledMessage;

    [SupplyParameterFromQuery(Name = "success")]
    public string? SuccessParam { get; set; }

    [SupplyParameterFromQuery(Name = "canceled")]
    public string? CanceledParam { get; set; }

    private static readonly PlanDisplay[] _plans =
    {
        new("Free",     "0 €",  BaustellenBob.Domain.Enums.Tier.Free,     "1",  "1",  "20",     false),
        new("Starter",  "19 €", BaustellenBob.Domain.Enums.Tier.Starter,  "10", "5",  "1.000",  true),
        new("Pro",      "39 €", BaustellenBob.Domain.Enums.Tier.Pro,      "50", "20", "10.000", true),
        new("Business", "79 €", BaustellenBob.Domain.Enums.Tier.Business, "∞",  "∞",  "∞",      true),
    };

    protected override async Task OnInitializedAsync()
    {
        _successMessage = SuccessParam == "1" ? "Abo erfolgreich abgeschlossen! Dein Tarif wird in Kürze aktualisiert." : null;
        _canceledMessage = CanceledParam == "1" ? "Checkout abgebrochen." : null;

        // Load account data
        _limits = await TierLimitService.GetCurrentLimitsAsync();
        _usage = await TierLimitService.GetUsageAsync();
        _logoPath = await TenantService.GetLogoPathAsync();
        _currencyCode = await TenantService.GetCurrencyCodeAsync();
        _workingDays = (await TenantService.GetWorkingDaysAsync()).ToHashSet();

        // Load Stripe data
        try
        {
            _stripeInfo = await StripeService.GetSubscriptionInfoAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Laden der Abo-Daten: {ex.Message}", Severity.Error);
        }
        _stripeLoading = false;
    }

    private void OnCurrencyChanged(string? value)
    {
        var normalized = (value ?? "EUR").Trim().ToUpperInvariant();
        _currencyCode = string.IsNullOrWhiteSpace(normalized) ? "EUR" : normalized;
        _currencyDirty = true;
    }

    private async Task SaveCurrency()
    {
        _savingCurrency = true;
        try
        {
            await TenantService.SetCurrencyCodeAsync(_currencyCode);
            _currencyDirty = false;
            Snackbar.Add($"Währung gespeichert: {_currencyCode}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Speichern der Währung: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingCurrency = false;
        }
    }

    private void OnWorkingDayToggled(DayOfWeek day, bool enabled)
    {
        if (enabled)
            _workingDays.Add(day);
        else
            _workingDays.Remove(day);

        _workingDaysDirty = true;
    }

    private async Task SaveWorkingDays()
    {
        _savingWorkingDays = true;
        try
        {
            await TenantService.SetWorkingDaysAsync(_workingDays);
            _workingDays = (await TenantService.GetWorkingDaysAsync()).ToHashSet();
            _workingDaysDirty = false;
            Snackbar.Add("Arbeitstage gespeichert.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Fehler beim Speichern der Arbeitstage: {ex.Message}", Severity.Error);
        }
        finally
        {
            _savingWorkingDays = false;
        }
    }

    private async Task OnLogoSelected(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file.Size > 2 * 1024 * 1024)
        {
            _logoError = "Logo darf maximal 2 MB groß sein.";
            return;
        }
        _logoError = null;
        _pendingLogo = file;

        using var ms = new MemoryStream();
        await file.OpenReadStream(2 * 1024 * 1024).CopyToAsync(ms);
        var base64 = Convert.ToBase64String(ms.ToArray());
        _previewUrl = $"data:{file.ContentType};base64,{base64}";
    }

    private async Task SaveLogo()
    {
        if (_pendingLogo is null) return;
        _savingLogo = true;
        _logoError = null;
        try
        {
            using var stream = _pendingLogo.OpenReadStream(2 * 1024 * 1024);
            _logoPath = await TenantService.UploadLogoAsync(_pendingLogo.Name, stream);
            _pendingLogo = null;
            _previewUrl = null;
            Snackbar.Add("Logo gespeichert.", Severity.Success);
        }
        catch (Exception ex)
        {
            _logoError = ex.Message;
        }
        finally
        {
            _savingLogo = false;
        }
    }

    private static Color TierColor(BaustellenBob.Domain.Enums.Tier tier) => tier switch
    {
        BaustellenBob.Domain.Enums.Tier.Free => Color.Default,
        BaustellenBob.Domain.Enums.Tier.Starter => Color.Info,
        BaustellenBob.Domain.Enums.Tier.Pro => Color.Success,
        BaustellenBob.Domain.Enums.Tier.Business => Color.Warning,
        _ => Color.Default
    };

    private static string TranslateStatus(string status) => status switch
    {
        "active" => "Aktiv",
        "past_due" => "Zahlung überfällig",
        "canceled" => "Gekündigt",
        "trialing" => "Testphase",
        "incomplete" => "Unvollständig",
        _ => status
    };

    private record PlanDisplay(string Name, string Price, BaustellenBob.Domain.Enums.Tier Tier, string Baustellen, string Mitarbeiter, string Fotos, bool PdfExport);
    private record WorkingDayOption(DayOfWeek Day, string Label);
}
