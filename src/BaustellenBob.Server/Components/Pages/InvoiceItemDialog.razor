<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Item.Description" Label="Beschreibung" Required="true" />
        <MudNumericField T="decimal" @bind-Value="Item.Quantity" Label="Menge" Min="0.01m" />
        <MudTextField @bind-Value="Item.Unit" Label="Einheit" Placeholder="Stk, m, kg..." />
        <MudNumericField T="decimal" @bind-Value="Item.UnitPrice" Label="Einzelpreis (€)" Min="0" Format="N2" />
        <MudText Typo="Typo.body1" Class="mt-2">
            Gesamt: @((Item.Quantity * Item.UnitPrice).ToString("N2")) €
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit"
                   Disabled="string.IsNullOrWhiteSpace(Item.Description)">OK</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public InvoiceItemDto Item { get; set; } = new();

    private void Cancel() => MudDialog.Cancel();
    private void Submit() => MudDialog.Close(DialogResult.Ok(true));
}
