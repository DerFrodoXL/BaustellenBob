@page "/employees"
@attribute [Authorize(Roles = "Admin")]

<PageTitle>Mitarbeiter</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Mitarbeiter</MudText>

<MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mb-4"
           OnClick="OpenCreateDialog" StartIcon="@Icons.Material.Filled.PersonAdd">
    Neuer Mitarbeiter
</MudButton>

@* Desktop: Table *@
<MudHidden Breakpoint="Breakpoint.SmAndDown">
    <MudTable Items="_users" Hover="true" Striped="true" Dense="true" Loading="_loading">
        <HeaderContent>
            <MudTh></MudTh>
            <MudTh>Name</MudTh>
            <MudTh>E-Mail</MudTh>
            <MudTh>Rolle</MudTh>
            <MudTh>Aktionen</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudAvatar Size="Size.Small">
                    @if (!string.IsNullOrEmpty(context.ProfilePicturePath))
                    {
                        <MudImage Src="@($"/uploads/{context.ProfilePicturePath}")" Alt="@context.Name" Style="width:100%;height:100%;object-fit:cover;" />
                    }
                    else
                    {
                        @context.Name[0].ToString().ToUpper()
                    }
                </MudAvatar>
            </MudTd>
            <MudTd DataLabel="Name">@context.Name</MudTd>
            <MudTd DataLabel="E-Mail">@context.Email</MudTd>
            <MudTd DataLabel="Rolle">
                <MudChip T="string" Size="Size.Small">@context.Role</MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                               OnClick="@(() => EditUser(context))" aria-label="Bearbeiten" />
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                               OnClick="@(() => DeleteUser(context))" aria-label="Löschen" />
            </MudTd>
        </RowTemplate>
    </MudTable>
</MudHidden>

@* Mobile: Cards *@
<MudHidden Breakpoint="Breakpoint.MdAndUp">
    @if (_loading)
    {
        <MudProgressCircular Indeterminate="true" />
    }
    else
    {
        <MudGrid>
            @foreach (var user in _users)
            {
                <MudItem xs="12">
                    <MudCard>
                        <MudCardContent>
                            <div class="d-flex justify-space-between align-center">
                                <div class="d-flex align-center gap-3">
                                    <MudAvatar Size="Size.Medium">
                                        @if (!string.IsNullOrEmpty(user.ProfilePicturePath))
                                        {
                                            <MudImage Src="@($"/uploads/{user.ProfilePicturePath}")" Alt="@user.Name" Style="width:100%;height:100%;object-fit:cover;" />
                                        }
                                        else
                                        {
                                            @user.Name[0].ToString().ToUpper()
                                        }
                                    </MudAvatar>
                                    <div>
                                        <MudText Typo="Typo.h6">@user.Name</MudText>
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary">@user.Email</MudText>
                                    </div>
                                </div>
                                <MudChip T="string" Size="Size.Small">@user.Role</MudChip>
                            </div>
                        </MudCardContent>
                        <MudCardActions>
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           OnClick="@(() => EditUser(user))" aria-label="Bearbeiten" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                           OnClick="@(() => DeleteUser(user))" aria-label="Löschen" />
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }
</MudHidden>

@code {
    [Inject] private IUserService UserService { get; set; } = null!;
    [Inject] private IDialogService DialogService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    private List<UserDto> _users = new();
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _loading = true;
        _users = await UserService.GetAllAsync();
        _loading = false;
    }

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<UserDialog>("Neuer Mitarbeiter");
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
            await LoadUsers();
    }

    private async Task EditUser(UserDto user)
    {
        var parameters = new DialogParameters<UserDialog>
        {
            { x => x.Existing, user }
        };
        var dialog = await DialogService.ShowAsync<UserDialog>("Mitarbeiter bearbeiten", parameters);
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
            await LoadUsers();
    }

    private async Task DeleteUser(UserDto user)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            "Mitarbeiter löschen",
            $"{user.Name} wirklich löschen?",
            yesText: "Löschen", cancelText: "Abbrechen");
        if (confirmed == true)
        {
            try
            {
                await UserService.DeleteAsync(user.Id);
                await LoadUsers();
                Snackbar.Add("Mitarbeiter gelöscht", Severity.Success);
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Fehler: {ex.Message}", Severity.Error);
            }
        }
    }
}
