@page "/projects"
@attribute [Authorize]

<PageTitle>Baustellen</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Baustellen</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="12" sm="5">
        <MudTextField T="string" @bind-Value="_search" Placeholder="Suche nach Name, Kunde, Adresse..."
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="300" TextChanged="OnSearchChanged" />
    </MudItem>
    <MudItem xs="8" sm="4">
        <MudSelect T="ProjectStatus?" Value="_statusFilter" Label="Status" Clearable="true"
                   ValueChanged="OnStatusFilterChanged">
            <MudSelectItem T="ProjectStatus?" Value="ProjectStatus.Active">Aktiv</MudSelectItem>
            <MudSelectItem T="ProjectStatus?" Value="ProjectStatus.Paused">Pausiert</MudSelectItem>
            <MudSelectItem T="ProjectStatus?" Value="ProjectStatus.Completed">Abgeschlossen</MudSelectItem>
            <MudSelectItem T="ProjectStatus?" Value="ProjectStatus.Archived">Archiviert</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem xs="4" sm="3" Class="d-flex align-end">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenCreateDialog" FullWidth="true">
            Neue Baustelle
        </MudButton>
    </MudItem>
</MudGrid>

@if (_loading)
{
    <div class="loading-center">
        <MudProgressCircular Indeterminate="true" />
    </div>
}
else if (!FilteredProjects.Any())
{
    <MudAlert Severity="Severity.Info">Keine Baustellen gefunden.</MudAlert>
}
else
{
    @* Desktop: Table *@
    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        <MudTable Items="FilteredProjects" Hover="true" Dense="true" Striped="true">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Kunde</MudTh>
                <MudTh>Adresse</MudTh>
                <MudTh>Status</MudTh>
                <MudTh>Aktionen</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Kunde">@context.CustomerName</MudTd>
                <MudTd DataLabel="Adresse">@context.Address</MudTd>
                <MudTd DataLabel="Status">
                    <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">
                        @context.Status
                    </MudChip>
                </MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Visibility" Href="@($"/projects/{context.Id}")" />
                    <AuthorizeView Roles="Admin" Context="authState">
                        <MudIconButton Icon="@Icons.Material.Filled.Archive" Color="Color.Warning"
                                       Disabled="@(context.Status == ProjectStatus.Archived)"
                                       OnClick="@(() => Archive(context))" />
                    </AuthorizeView>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudHidden>

    @* Mobile: Cards *@
    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <MudGrid>
            @foreach (var b in FilteredProjects)
            {
                <MudItem xs="12">
                    <MudCard>
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@b.Name</MudText>
                            <MudText Typo="Typo.body2">@b.CustomerName</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@b.Address</MudText>
                            <MudChip T="string" Color="@GetStatusColor(b.Status)" Size="Size.Small" Class="mt-2">
                                @b.Status
                            </MudChip>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Href="@($"/projects/{b.Id}")" Variant="Variant.Text" Color="Color.Primary">
                                Details
                            </MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    </MudHidden>
}

@code {
    [Inject] private IProjectService ProjectService { get; set; } = null!;
    [Inject] private IDialogService DialogService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    private List<ProjectDto> _projects = new();
    private bool _loading = true;
    private string _search = string.Empty;
    private ProjectStatus? _statusFilter;

    private IEnumerable<ProjectDto> FilteredProjects => _projects
        .Where(p => _statusFilter is null || p.Status == _statusFilter)
        .Where(p => string.IsNullOrWhiteSpace(_search)
            || p.Name.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || p.CustomerName.Contains(_search, StringComparison.OrdinalIgnoreCase)
            || p.Address.Contains(_search, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _loading = true;
        _projects = await ProjectService.GetAllAsync();
        _loading = false;
    }

    private void OnSearchChanged(string value) => _search = value;
    private void OnStatusFilterChanged(ProjectStatus? value) => _statusFilter = value;

    private async Task Archive(ProjectDto project)
    {
        bool? confirmed = await DialogService.ShowMessageBoxAsync(
            "Baustelle archivieren",
            $"Baustelle '{project.Name}' wirklich archivieren?\n\n" +
            "Danach ist sie nicht mehr aktiv nutzbar und diese Aktion kann nicht rückgängig gemacht werden.\n" +
            "Für das Tier-Limit zahlen nur aktive Baustellen.",
            yesText: "Endgültig archivieren",
            cancelText: "Abbrechen");

        if (confirmed != true)
            return;

        await ProjectService.ArchiveAsync(project.Id);
        Snackbar.Add("Baustelle archiviert", Severity.Success);
        await LoadData();
    }

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<ProjectDialog>("Neue Baustelle",
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        var result = await dialog.Result;
        if (result is not null && !result.Canceled)
        {
            await LoadData();
        }
    }

    private static Color GetStatusColor(ProjectStatus status) => status switch
    {
        ProjectStatus.Active => Color.Success,
        ProjectStatus.Paused => Color.Warning,
        ProjectStatus.Completed => Color.Info,
        ProjectStatus.Archived => Color.Default,
        _ => Color.Default
    };
}
