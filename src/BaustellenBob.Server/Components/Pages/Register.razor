@page "/register"
@attribute [AllowAnonymous]
@layout BaustellenBob.Server.Components.Layout.EmptyLayout

<PageTitle>BaustellenBob - Registrierung</PageTitle>

<div style="display:flex; justify-content:center; align-items:center; min-height:100vh;">
    <MudCard Style="width:440px; max-width:95vw;">
        <MudCardHeader>
            <MudText Typo="Typo.h5" Align="Align.Center" Style="width:100%">
                BaustellenBob — Registrierung
            </MudText>
        </MudCardHeader>
        <MudCardContent>
            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
            }
            <form method="post" action="/api/auth/register">
                <AntiforgeryToken />
                <div class="mud-input-control mud-input-input-control mb-3">
                    <label class="mud-input-label" for="companyName">Firmenname</label>
                    <input id="companyName" name="companyName" type="text" required
                           class="mud-input-slot mud-input-root mud-input-root-outlined"
                           style="width:100%; padding:10px;" />
                </div>
                <div class="mud-input-control mud-input-input-control mb-3">
                    <label class="mud-input-label" for="adminName">Ihr Name</label>
                    <input id="adminName" name="adminName" type="text" required
                           class="mud-input-slot mud-input-root mud-input-root-outlined"
                           style="width:100%; padding:10px;" />
                </div>
                <div class="mud-input-control mud-input-input-control mb-3">
                    <label class="mud-input-label" for="email">E-Mail</label>
                    <input id="email" name="email" type="email" required
                           class="mud-input-slot mud-input-root mud-input-root-outlined"
                           style="width:100%; padding:10px;" />
                </div>
                <div class="mud-input-control mud-input-input-control mb-3">
                    <label class="mud-input-label" for="password">Passwort</label>
                    <input id="password" name="password" type="password" required minlength="6"
                           class="mud-input-slot mud-input-root mud-input-root-outlined"
                           style="width:100%; padding:10px;" />
                </div>
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                           Color="Color.Primary" FullWidth="true" Class="mt-2">
                    Kostenlos registrieren
                </MudButton>
            </form>
        </MudCardContent>
        <MudCardActions Style="justify-content:center;">
            <MudLink Href="/login" Typo="Typo.body2">Bereits registriert? Anmelden</MudLink>
        </MudCardActions>
    </MudCard>
</div>

@code {
    private string? _error;

    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorParam { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(ErrorParam))
            _error = ErrorParam;
    }
}
