@page "/register"
@attribute [AllowAnonymous]
@layout BaustellenBob.Server.Components.Layout.EmptyLayout

<PageTitle>Structra - Registrierung</PageTitle>

<div style="display:flex; justify-content:center; align-items:center; min-height:100vh;">
    <MudCard Style="width:440px; max-width:95vw;">
        <MudCardHeader>
            <div style="width:100%; text-align:center;">
                <MudImage Src="/structra-logo.png" Alt="Structra Logo" Style="max-width:240px; width:100%; height:auto; margin:0 auto 8px auto;" />
                <MudText Typo="Typo.h6" Align="Align.Center" Style="width:100%">
                    Registrierung
                </MudText>
            </div>
        </MudCardHeader>
        <MudCardContent>
            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
            }
            <form method="post" action="/api/auth/register">
                <AntiforgeryToken />
                <MudTextField T="string"
                              Label="Firmenname"
                              Name="companyName"
                              InputId="companyName"
                              Required="true"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Class="mb-3" />
                <MudTextField T="string"
                              Label="Ihr Name"
                              Name="adminName"
                              InputId="adminName"
                              Required="true"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Class="mb-3" />
                <MudTextField T="string"
                              Label="E-Mail"
                              Name="email"
                              InputId="email"
                              InputType="InputType.Email"
                              Required="true"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Class="mb-3" />
                <MudTextField T="string"
                              Label="Passwort"
                              Name="password"
                              InputId="password"
                              InputType="InputType.Password"
                              Required="true"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Class="mb-3"
                              MinLength="6" />
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                           Color="Color.Primary" FullWidth="true" Class="mt-2">
                    Kostenlos registrieren
                </MudButton>
            </form>
        </MudCardContent>
        <MudCardActions Style="justify-content:center;">
            <MudLink Href="/login" Typo="Typo.body2">Bereits registriert? Anmelden</MudLink>
        </MudCardActions>
    </MudCard>
</div>

@code {
    private string? _error;

    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorParam { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(ErrorParam))
            _error = ErrorParam;
    }
}
