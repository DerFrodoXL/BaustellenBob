@page "/register"
@attribute [AllowAnonymous]
@layout BaustellenBob.Server.Components.Layout.EmptyLayout

<PageTitle>Structra - Registrierung</PageTitle>

<div style="display:flex; justify-content:center; align-items:center; min-height:100vh;">
    <MudCard Style="width:440px; max-width:95vw;">
        <MudCardHeader>
            <div style="width:100%; text-align:center;">
                <MudImage Src="/structra-logo.png" Alt="Structra Logo" Style="max-width:240px; width:100%; height:auto; margin:0 auto 8px auto;" />
                <MudText Typo="Typo.h6" Align="Align.Center" Style="width:100%">
                    Registrierung
                </MudText>
            </div>
        </MudCardHeader>
        <MudCardContent>
            @if (_error is not null)
            {
                <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
            }
                        <form method="post" action="/api/auth/register"
                                    onsubmit="const companyName=document.getElementById('companyName'); const adminName=document.getElementById('adminName'); const email=document.getElementById('email'); const password=document.getElementById('password'); const hiddenCompanyName=document.getElementById('companyName_hidden'); const hiddenAdminName=document.getElementById('adminName_hidden'); const hiddenEmail=document.getElementById('email_hidden'); const hiddenPassword=document.getElementById('password_hidden'); if(hiddenCompanyName&&companyName){hiddenCompanyName.value=companyName.value;} if(hiddenAdminName&&adminName){hiddenAdminName.value=adminName.value;} if(hiddenEmail&&email){hiddenEmail.value=email.value;} if(hiddenPassword&&password){hiddenPassword.value=password.value;}">
                <AntiforgeryToken />
                                <input type="hidden" id="companyName_hidden" name="companyName" />
                                <input type="hidden" id="adminName_hidden" name="adminName" />
                                <input type="hidden" id="email_hidden" name="email" />
                                <input type="hidden" id="password_hidden" name="password" />
                <MudTextField T="string"
                              Label="Firmenname"
                              InputId="companyName"
                              Required="true"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Class="mb-3" />
                <MudTextField T="string"
                              Label="Ihr Name"
                              InputId="adminName"
                              Required="true"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Class="mb-3" />
                <MudTextField T="string"
                              Label="E-Mail"
                              InputId="email"
                              InputType="InputType.Email"
                              Required="true"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Class="mb-3" />
                <MudTextField T="string"
                              Label="Passwort"
                              InputId="password"
                              InputType="InputType.Password"
                              Required="true"
                              Variant="Variant.Outlined"
                              FullWidth="true"
                              Margin="Margin.Dense"
                              Class="mb-3"
                              HelperText="Mindestens 6 Zeichen" />
                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled"
                           Color="Color.Primary" FullWidth="true" Class="mt-2">
                    Kostenlos registrieren
                </MudButton>
            </form>
        </MudCardContent>
        <MudCardActions Style="flex-direction:column; align-items:center; gap:8px;">
            <MudLink Href="/login" Typo="Typo.body2">Bereits registriert? Anmelden</MudLink>
            <div style="display:flex; gap:12px; flex-wrap:wrap; justify-content:center;">
                <MudLink Href="/impressum" Typo="Typo.caption">Impressum</MudLink>
                <MudLink Href="/agb" Typo="Typo.caption">AGB</MudLink>
                <MudLink Href="/tos" Typo="Typo.caption">ToS</MudLink>
            </div>
        </MudCardActions>
    </MudCard>
</div>

@code {
    private string? _error;

    [SupplyParameterFromQuery(Name = "error")]
    public string? ErrorParam { get; set; }

    protected override void OnInitialized()
    {
        if (!string.IsNullOrEmpty(ErrorParam))
            _error = ErrorParam;
    }
}
