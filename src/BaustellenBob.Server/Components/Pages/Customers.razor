@page "/customers"
@attribute [Authorize]

<PageTitle>Kunden</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Kunden</MudText>

<MudGrid Class="mb-4">
    <MudItem xs="8" sm="9">
        <MudTextField T="string" @bind-Value="_search" Placeholder="Suche nach Name, Firma, Ort…"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                      Immediate="true" DebounceInterval="300" TextChanged="@(v => { _search = v; StateHasChanged(); })" />
    </MudItem>
    <MudItem xs="4" sm="3" Class="d-flex align-end">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.PersonAdd"
                   OnClick="OpenCreateDialog" FullWidth="true">
            Neuer Kunde
        </MudButton>
    </MudItem>
</MudGrid>

@if (_loading)
{
    <div class="loading-center">
        <MudProgressCircular Indeterminate="true" />
    </div>
}
else if (!Filtered.Any())
{
    <MudAlert Severity="Severity.Info">Keine Kunden gefunden.</MudAlert>
}
else
{
    @* Desktop *@
    <MudHidden Breakpoint="Breakpoint.SmAndDown">
        <MudTable Items="Filtered" Hover="true" Dense="true" Striped="true">
            <HeaderContent>
                <MudTh>Name</MudTh>
                <MudTh>Firma</MudTh>
                <MudTh>Telefon</MudTh>
                <MudTh>E-Mail</MudTh>
                <MudTh>Ort</MudTh>
                <MudTh>Aktionen</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Name">@context.Name</MudTd>
                <MudTd DataLabel="Firma">@context.Company</MudTd>
                <MudTd DataLabel="Telefon">
                    @if (!string.IsNullOrEmpty(context.Phone))
                    {
                        <MudLink Href="@($"tel:{context.Phone}")">@context.Phone</MudLink>
                    }
                </MudTd>
                <MudTd DataLabel="E-Mail">
                    @if (!string.IsNullOrEmpty(context.Email))
                    {
                        <MudLink Href="@($"mailto:{context.Email}")">@context.Email</MudLink>
                    }
                </MudTd>
                <MudTd DataLabel="Ort">@context.City</MudTd>
                <MudTd>
                    <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                   OnClick="@(() => OpenEditDialog(context))" />
                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                   OnClick="@(() => Delete(context))" />
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudHidden>

    @* Mobile: Cards *@
    <MudHidden Breakpoint="Breakpoint.MdAndUp">
        <MudGrid>
            @foreach (var c in Filtered)
            {
                <MudItem xs="12">
                    <MudCard>
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@c.Name</MudText>
                            @if (!string.IsNullOrEmpty(c.Company))
                            {
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">@c.Company</MudText>
                            }
                            @if (!string.IsNullOrEmpty(c.Phone))
                            {
                                <MudText Typo="Typo.body2">
                                    <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Class="mr-1" />
                                    <MudLink Href="@($"tel:{c.Phone}")">@c.Phone</MudLink>
                                </MudText>
                            }
                            @if (!string.IsNullOrEmpty(c.Email))
                            {
                                <MudText Typo="Typo.body2">
                                    <MudIcon Icon="@Icons.Material.Filled.Email" Size="Size.Small" Class="mr-1" />
                                    <MudLink Href="@($"mailto:{c.Email}")">@c.Email</MudLink>
                                </MudText>
                            }
                            @if (!string.IsNullOrEmpty(c.AddressLine))
                            {
                                <MudText Typo="Typo.body2" Class="mud-text-secondary">@c.AddressLine</MudText>
                            }
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton StartIcon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       OnClick="@(() => OpenEditDialog(c))">Bearbeiten</MudButton>
                            <MudButton StartIcon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => Delete(c))">Löschen</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    </MudHidden>
}

@code {
    [Inject] private ICustomerService CustomerService { get; set; } = null!;
    [Inject] private IDialogService DialogService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    private List<CustomerDto> _customers = new();
    private string _search = string.Empty;
    private bool _loading = true;

    private IEnumerable<CustomerDto> Filtered => string.IsNullOrWhiteSpace(_search)
        ? _customers
        : _customers.Where(c =>
            c.Name.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            (c.Company?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (c.City?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false) ||
            (c.Email?.Contains(_search, StringComparison.OrdinalIgnoreCase) ?? false));

    protected override async Task OnInitializedAsync()
    {
        _customers = await CustomerService.GetAllAsync();
        _loading = false;
    }

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<CustomerDialog>("Neuer Kunde");
        var result = await dialog.Result;
        if (result is { Canceled: false })
            _customers = await CustomerService.GetAllAsync();
    }

    private async Task OpenEditDialog(CustomerDto customer)
    {
        var parameters = new DialogParameters<CustomerDialog> { { x => x.Existing, customer } };
        var dialog = await DialogService.ShowAsync<CustomerDialog>("Kunde bearbeiten", parameters);
        var result = await dialog.Result;
        if (result is { Canceled: false })
            _customers = await CustomerService.GetAllAsync();
    }

    private async Task Delete(CustomerDto customer)
    {
        try
        {
            await CustomerService.DeleteAsync(customer.Id);
            _customers.Remove(customer);
            Snackbar.Add($"\"{customer.DisplayName}\" gelöscht.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
    }
}
