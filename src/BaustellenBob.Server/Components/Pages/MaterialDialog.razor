<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(_isEdit ? "Material bearbeiten" : "Material hinzufügen")</MudText>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="Model.Name" Label="Materialname" Required="true" Class="mb-3" />
        <MudGrid>
            <MudItem xs="6">
                <MudNumericField @bind-Value="Model.Quantity" Label="Menge" Min="0.01m" Step="0.5m" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField @bind-Value="Model.Unit" Label="Einheit" Placeholder="Stk, m, kg, Rolle…" />
            </MudItem>
        </MudGrid>
        <MudNumericField @bind-Value="Model.UnitPrice" Label="Einzelpreis (€)" Min="0m" Step="0.5m" Class="mt-3" />
        @if (Model.Quantity > 0 && Model.UnitPrice > 0)
        {
            <MudText Typo="Typo.body2" Class="mt-2 mud-text-secondary">
                Gesamt: @((Model.Quantity * Model.UnitPrice).ToString("N2")) €
            </MudText>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Speichern</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Inject] private IMaterialService MaterialService { get; set; } = null!;

    [Parameter] public Guid ProjectId { get; set; }
    [Parameter] public MaterialEntryDto? Existing { get; set; }

    private MaterialEntryDto Model { get; set; } = new() { Quantity = 1, UnitPrice = 0 };
    private bool _isEdit;

    protected override void OnParametersSet()
    {
        if (Existing is not null)
        {
            _isEdit = true;
            Model = new MaterialEntryDto
            {
                Id = Existing.Id,
                ProjectId = Existing.ProjectId,
                Name = Existing.Name,
                Quantity = Existing.Quantity,
                Unit = Existing.Unit,
                UnitPrice = Existing.UnitPrice
            };
        }
    }

    private async Task Save()
    {
        if (_isEdit)
            await MaterialService.UpdateAsync(Model);
        else
            await MaterialService.CreateAsync(ProjectId, Model);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();
}
