@page "/"
@attribute [Authorize]

<PageTitle>Structra - Dashboard</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Dashboard</MudText>

@if (_dashboard is null)
{
    <MudProgressCircular Indeterminate="true" />
}
else
{
    <MudGrid>
        <MudItem xs="6" sm="3">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.h3" Align="Align.Center">@_dashboard.ActiveProjects</MudText>
                    <MudText Typo="Typo.subtitle1" Align="Align.Center">Aktive Baustellen</MudText>
                </MudCardContent>
                <MudCardActions>
                    <MudButton Href="/projects" Variant="Variant.Text" Color="Color.Primary">Anzeigen</MudButton>
                </MudCardActions>
            </MudCard>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.h3" Align="Align.Center">@_dashboard.TotalPhotos</MudText>
                    <MudText Typo="Typo.subtitle1" Align="Align.Center">Fotos gesamt</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.h3" Align="Align.Center">@_dashboard.TotalReports</MudText>
                    <MudText Typo="Typo.subtitle1" Align="Align.Center">Rapporte gesamt</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="6" sm="3">
            <MudCard>
                <MudCardContent>
                    <MudText Typo="Typo.h3" Align="Align.Center">@_dashboard.TotalHours.ToString("0.#")</MudText>
                    <MudText Typo="Typo.subtitle1" Align="Align.Center">Stunden gesamt</MudText>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    @if (_dashboard.RecentActivities.Any())
    {
        <MudText Typo="Typo.h6" Class="mt-6 mb-2">Letzte Aktivitäten</MudText>
        <MudCard>
            <MudList T="string" Dense="true">
                @foreach (var a in _dashboard.RecentActivities)
                {
                    <MudListItem Icon="@GetActivityIcon(a.Icon)">
                        <div class="d-flex flex-column">
                            <MudText Typo="Typo.body2">@a.Text</MudText>
                            <MudText Typo="Typo.caption" Class="mud-text-secondary">
                                @a.Timestamp.ToLocalTime().ToString("dd.MM.yyyy HH:mm") —
                                <MudLink Href="@($"/projects/{a.ProjectId}")">@a.ProjectName</MudLink>
                            </MudText>
                        </div>
                    </MudListItem>
                }
            </MudList>
        </MudCard>
    }

    @if (_dashboard.RecentProjects.Any())
    {
        <MudText Typo="Typo.h6" Class="mt-6 mb-2">Aktive Baustellen</MudText>
        <MudGrid>
            @foreach (var b in _dashboard.RecentProjects)
            {
                <MudItem xs="12" sm="6" md="4">
                    <MudCard>
                        <MudCardContent>
                            <MudText Typo="Typo.h6">@b.Name</MudText>
                            <MudText Typo="Typo.body2" Class="mud-text-secondary">@b.CustomerName — @b.Address</MudText>
                        </MudCardContent>
                        <MudCardActions>
                            <MudButton Href="@($"/projects/{b.Id}")" Variant="Variant.Text" Color="Color.Primary">Öffnen</MudButton>
                        </MudCardActions>
                    </MudCard>
                </MudItem>
            }
        </MudGrid>
    }

    @* Timeline: Baustellen & Mitarbeiter – nur für Admin/Büro *@
    <AuthorizeView Roles="Admin,Office">
        <Authorized>
            @if (_dashboard.TimelineProjects.Any())
            {
                <MudText Typo="Typo.h6" Class="mt-6 mb-2">
                    <MudIcon Icon="@Icons.Material.Filled.Engineering" Class="mr-1" Style="vertical-align:middle;" />
                    Heute auf den Baustellen
                </MudText>

                <MudTimeline TimelinePosition="TimelinePosition.Start">
                    @foreach (var project in _dashboard.TimelineProjects)
                    {
                        var hasWorkers = project.Workers.Any();
                        <MudTimelineItem Color="@(hasWorkers ? Color.Primary : Color.Default)"
                                         Variant="Variant.Filled"
                                         Icon="@(hasWorkers ? Icons.Material.Filled.Construction : Icons.Material.Filled.WarningAmber)"
                                         Size="Size.Medium">
                            <ItemContent>
                                <MudCard Outlined="true" Class="mb-2">
                                    <MudCardContent Class="pa-3">
                                        <div class="d-flex justify-space-between align-center flex-wrap">
                                            <div>
                                                <MudLink Typo="Typo.subtitle1" Href="@($"/projects/{project.ProjectId}")" Class="fw-bold">
                                                    @project.ProjectName
                                                </MudLink>
                                                <MudText Typo="Typo.body2" Class="mud-text-secondary">
                                                    @project.Customer@(string.IsNullOrEmpty(project.Address) ? "" : $" — {project.Address}")
                                                </MudText>
                                                <MudText Typo="Typo.caption" Class="mud-text-secondary mt-1 d-flex align-center">
                                                    <MudIcon Icon="@(hasWorkers ? Icons.Material.Filled.CheckCircle : Icons.Material.Filled.WarningAmber)"
                                                             Size="Size.Small" Class="mr-1"
                                                             Color="@(hasWorkers ? Color.Success : Color.Warning)" />
                                                    @(hasWorkers ? "Aktiv besetzt durch:" : "Heute nicht besetzt")
                                                </MudText>
                                            </div>
                                            <MudChip T="string" Size="Size.Small"
                                                     Color="@(hasWorkers ? Color.Success : Color.Warning)">
                                                @(hasWorkers ? $"{project.Workers.Count} MA" : "Nicht besetzt")
                                            </MudChip>
                                        </div>

                                        @if (hasWorkers)
                                        {
                                            <div class="d-flex flex-wrap gap-3 mt-3">
                                                @foreach (var w in project.Workers)
                                                {
                                                    <div class="d-flex align-start gap-2">
                                                        <MudAvatar Size="Size.Small" Color="Color.Secondary">
                                                            @if (!string.IsNullOrEmpty(w.ProfilePicturePath))
                                                            {
                                                                <img src="@($"/uploads/{w.ProfilePicturePath}")" alt="@w.Name"
                                                                     style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                                                            }
                                                            else
                                                            {
                                                                @w.Name[0].ToString().ToUpper()
                                                            }
                                                        </MudAvatar>
                                                        <div>
                                                            <MudText Typo="Typo.body2">@w.Name</MudText>
                                                            @if (!string.IsNullOrEmpty(w.Notes))
                                                            {
                                                                <MudText Typo="Typo.caption" Class="mud-text-secondary d-flex align-center">
                                                                    <MudIcon Icon="@Icons.Material.Filled.Notes" Size="Size.Small" Class="mr-1" />
                                                                    @w.Notes
                                                                </MudText>
                                                            }
                                                            <MudText Typo="Typo.caption" Class="mud-text-secondary d-flex align-center mt-1">
                                                                <MudIcon Icon="@Icons.Material.Filled.DateRange" Size="Size.Small" Class="mr-1" />
                                                                @w.StartDate.ToString("dd.MM.") – @w.EndDate.ToString("dd.MM.")
                                                            </MudText>
                                                        </div>
                                                    </div>
                                                }
                                            </div>
                                        }
                                    </MudCardContent>
                                </MudCard>
                            </ItemContent>
                        </MudTimelineItem>
                    }
                </MudTimeline>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Class="mt-6">Keine aktiven Baustellen vorhanden.</MudAlert>
            }
        </Authorized>
    </AuthorizeView>
}

@code {
    [Inject] private IDashboardService DashboardService { get; set; } = null!;

    private DashboardDto? _dashboard;

    protected override async Task OnInitializedAsync()
    {
        _dashboard = await DashboardService.GetDashboardAsync();
    }

    private static string GetActivityIcon(string icon) => icon switch
    {
        "PhotoCamera" => Icons.Material.Filled.PhotoCamera,
        "Assignment" => Icons.Material.Filled.Assignment,
        _ => Icons.Material.Filled.Info
    };
}
