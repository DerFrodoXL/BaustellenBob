<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEdit ? "Baustelle bearbeiten" : "Neue Baustelle")</MudText>
    </TitleContent>
    <DialogContent>
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
        }
        <MudTextField @bind-Value="Model.Name" Label="Name" Required="true" Class="mb-3" />
        <MudSelect T="Guid?" @bind-Value="Model.CustomerId" Label="Kunde" Clearable="true" Class="mb-3"
                   ToStringFunc="@(id => _customers.FirstOrDefault(c => c.Id == id)?.DisplayName ?? string.Empty)">
            @foreach (var c in _customers)
            {
                <MudSelectItem T="Guid?" Value="@c.Id">@c.DisplayName</MudSelectItem>
            }
        </MudSelect>
        <MudTextField @bind-Value="Model.Address" Label="Adresse" Class="mb-3" />
        <MudDatePicker @bind-Date="_startDate" Label="Startdatum" Class="mb-3" />
        <MudTextField @bind-Value="Model.Description" Label="Beschreibung" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Speichern</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Inject] private IProjectService ProjectService { get; set; } = null!;
    [Inject] private ICustomerService CustomerService { get; set; } = null!;

    [Parameter] public ProjectDto? Existing { get; set; }

    private ProjectDto Model { get; set; } = new() { StartDate = DateTime.Today };
    private DateTime? _startDate = DateTime.Today;
    private List<CustomerDto> _customers = new();
    private bool IsEdit => Existing is not null;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        _customers = await CustomerService.GetAllAsync();
        if (Existing is not null)
        {
            Model = Existing;
            _startDate = Existing.StartDate;
        }
    }

    private async Task Save()
    {
        _error = null;
        try
        {
            Model.StartDate = _startDate ?? DateTime.Today;
            if (IsEdit)
                await ProjectService.UpdateAsync(Model);
            else
                await ProjectService.CreateAsync(Model);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (TierLimitExceededException ex)
        {
            _error = ex.Message;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
