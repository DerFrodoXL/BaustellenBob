<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">@(IsEdit ? "Baustelle bearbeiten" : "Neue Baustelle")</MudText>
    </TitleContent>
    <DialogContent>
        @if (_error is not null)
        {
            <MudAlert Severity="Severity.Error" Class="mb-3">@_error</MudAlert>
        }
        <MudTextField @bind-Value="Model.Name" Label="Name" Required="true" Class="mb-3" />
        <MudSelect T="Guid?" Value="_selectedCustomerId" ValueChanged="OnCustomerChanged" Label="Kunde" Clearable="true" Class="mb-3"
                   ToStringFunc="@(id => _customers.FirstOrDefault(c => c.Id == id)?.DisplayName ?? string.Empty)">
            @foreach (var c in _customers)
            {
                <MudSelectItem T="Guid?" Value="@c.Id">@c.DisplayName</MudSelectItem>
            }
        </MudSelect>
        @if (CanSuggestCustomerAddress)
        {
            <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3 d-flex align-center justify-space-between">
                <span>Kundenadresse verfügbar: @_selectedCustomerAddress</span>
                <MudButton Variant="Variant.Text" Size="Size.Small" Color="Color.Primary" OnClick="ApplyCustomerAddress">
                    Ubernehmen
                </MudButton>
            </MudAlert>
        }
        <MudTextField @bind-Value="Model.Address" Label="Adresse" HelperText="Abweichende Baustellenadresse moglich" Class="mb-3" />
        <MudDatePicker @bind-Date="_startDate" Label="Startdatum" Class="mb-3" />
        <MudDatePicker @bind-Date="_endDate" Label="Enddatum" HelperText="Optional" Class="mb-3" />
        <MudTextField @bind-Value="Model.Description" Label="Beschreibung" Lines="3" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Abbrechen</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Save">Speichern</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Inject] private IProjectService ProjectService { get; set; } = null!;
    [Inject] private ICustomerService CustomerService { get; set; } = null!;

    [Parameter] public ProjectDto? Existing { get; set; }

    private ProjectDto Model { get; set; } = new() { StartDate = DateTime.Today };
    private DateTime? _startDate = DateTime.Today;
    private DateTime? _endDate;
    private List<CustomerDto> _customers = new();
    private Guid? _selectedCustomerId;
    private string _selectedCustomerAddress = string.Empty;
    private bool IsEdit => Existing is not null;
    private string? _error;
    private bool CanSuggestCustomerAddress =>
        !string.IsNullOrWhiteSpace(_selectedCustomerAddress)
        && !string.Equals(Model.Address?.Trim(), _selectedCustomerAddress, StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        _customers = await CustomerService.GetAllAsync();
        if (Existing is not null)
        {
            Model = Existing;
            _startDate = Existing.StartDate;
            _endDate = Existing.EndDate;
        }

        _selectedCustomerId = Model.CustomerId;
        RefreshSelectedCustomerAddress();
    }

    private void OnCustomerChanged(Guid? customerId)
    {
        _selectedCustomerId = customerId;
        Model.CustomerId = customerId;

        RefreshSelectedCustomerAddress();

        if (string.IsNullOrWhiteSpace(Model.Address))
            ApplyCustomerAddress();
    }

    private void RefreshSelectedCustomerAddress()
    {
        var customer = _customers.FirstOrDefault(c => c.Id == _selectedCustomerId);
        _selectedCustomerAddress = customer?.AddressLine?.Trim() ?? string.Empty;
    }

    private void ApplyCustomerAddress()
    {
        if (string.IsNullOrWhiteSpace(_selectedCustomerAddress))
            return;

        Model.Address = _selectedCustomerAddress;
    }

    private async Task Save()
    {
        _error = null;
        try
        {
            Model.StartDate = _startDate ?? DateTime.Today;
            Model.EndDate = _endDate;
            if (IsEdit)
                await ProjectService.UpdateAsync(Model);
            else
                await ProjectService.CreateAsync(Model);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (TierLimitExceededException ex)
        {
            _error = ex.Message;
        }
    }

    private void Cancel() => MudDialog.Cancel();
}
