@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.AspNetCore.Components.Authorization
@using System.Security.Claims
@using BaustellenBob.Server.Services

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />

        @* Company logo + name on the left *@
        @if (!string.IsNullOrEmpty(_logoPath))
        {
            <img src="@($"/uploads/{_logoPath}")" alt="Logo"
                 style="height:36px;max-width:130px;object-fit:contain;margin-left:8px;border-radius:4px;" />
            <MudHidden Breakpoint="Breakpoint.Xs">
                <MudText Typo="Typo.h6" Class="ml-2">@_tenantName</MudText>
            </MudHidden>
        }
        else
        {
            <MudText Typo="Typo.h6" Class="ml-3">@(_tenantName ?? "BaustellenBob")</MudText>
        }

        <MudSpacer />

        <AuthorizeView>
            <Authorized>
                @* User name – hidden on xs *@
                <MudHidden Breakpoint="Breakpoint.Xs">
                    <MudText Typo="Typo.body2" Class="mr-3">@context.User.Identity?.Name</MudText>
                </MudHidden>

                @* User avatar *@
                <MudAvatar Style="width:36px;height:36px;margin-right:8px;" Color="Color.Secondary">
                    @if (!string.IsNullOrEmpty(_userAvatarPath))
                    {
                        <img src="@($"/uploads/{_userAvatarPath}?v={_userAvatarVersion}")" alt="Profilbild"
                             style="width:100%;height:100%;object-fit:cover;border-radius:50%;" />
                    }
                    else
                    {
                        @((context.User.Identity?.Name ?? "?").Substring(0, 1).ToUpper())
                    }
                </MudAvatar>

                <form method="post" action="/api/auth/logout">
                    <AntiforgeryToken />
                    <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                                   ButtonType="ButtonType.Submit" aria-label="Abmelden" />
                </form>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent Class="px-4 pb-4">
        @Body
    </MudMainContent>
</MudLayout>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    [Inject] private ITenantService TenantService { get; set; } = null!;
    [Inject] private IUserService UserService { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = null!;
    [Inject] private UserUiStateService UserUiStateService { get; set; } = null!;

    private bool _drawerOpen = true;
    private string? _logoPath;
    private string? _tenantName;
    private string? _userAvatarPath;
    private Guid? _currentUserId;
    private long _userAvatarVersion;

    protected override async Task OnInitializedAsync()
    {
        UserUiStateService.AvatarChanged += OnAvatarChanged;

        // Tenant name comes from claims – no DB needed, safe during prerender
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            _tenantName = authState.User.FindFirst("TenantName")?.Value;
        }
        catch { }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        // DB calls only run after the interactive SignalR circuit is established
        try
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated != true) return;

            var userIdClaim = user.FindFirst(ClaimTypes.NameIdentifier)?.Value;
            if (Guid.TryParse(userIdClaim, out var userId))
            {
                _currentUserId = userId;
                await LoadLogo();
                await LoadUserAvatar(userId);
            }
            else
                await LoadLogo();

            StateHasChanged();
        }
        catch { }
    }

    private async Task LoadLogo()
    {
        try { _logoPath = await TenantService.GetLogoPathAsync(); } catch { }
    }

    private async Task LoadUserAvatar(Guid userId)
    {
        try
        {
            _userAvatarPath = await UserService.GetProfilePicturePathAsync(userId);
            _userAvatarVersion = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        }
        catch { }
    }

    private void OnAvatarChanged()
    {
        _ = InvokeAsync(async () =>
        {
            if (_currentUserId is null) return;
            await LoadUserAvatar(_currentUserId.Value);
            StateHasChanged();
        });
    }

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    public void Dispose()
    {
        UserUiStateService.AvatarChanged -= OnAvatarChanged;
    }
}
